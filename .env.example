# Copy this file to .env and fill in your keys
# (Or use: paper-demo-agent key set KEY_NAME value)

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
OPENAI_API_KEY=sk-...

# Google Gemini
GOOGLE_API_KEY=AIza...

# DeepSeek
DEEPSEEK_API_KEY=sk-...

# Qwen (Alibaba DashScope)
QWEN_API_KEY=sk-...

# MiniMax (both required)
MINIMAX_API_KEY=...
MINIMAX_GROUP_ID=...

# Hugging Face (for model search and gated models)
HUGGINGFACE_TOKEN=hf_...
